<!DOCTYPE html>
<html lang="ro">

<head>
    <meta name="description"
        content="Camera Obscura ofera o varietate de echipamente fotografice, in special camere si obiective, cu optiunea de achizitie online si livrare prin curier.">
    <meta name="keywords"
        content="magazin, camera, camera foto, aparat foto, aparat mirrorless, dSLR, mirrorless, fotografie, obiectiv, obiective, Canon, Nikon, Sony, Fujifilm">

    <title>Cofetăria Dulcelind - <%- locals.prod.nume %></title>
    <%- include("../fragmente/head") %>
        <link href="/resurse/css/produs.css" type="text/css" rel="stylesheet" />
</head>

<%- include("../fragmente/header") %>
    <main>
        <section>
            <h2>Pagină produs</h2>
            <article id="art-produs">
                <h3>Model: <span class="nume"><%- locals.prod.nume %></span></h3>

                <p>Preț: <span class="pret"><%- locals.prod.pret %></span> RON</p>
                <p>Descriere: <span class="descriere"><%- locals.prod.descriere %></span></p>
                <p>Brand: <span class="brand"><%- locals.prod.brand %></span></p>
                <p>Tip cameră: <span class="tip_cam"><%- locals.prod.tip_cam %></span></p>
                <p>Dimensiune senzor: <span class="marime_senzor"><%- locals.prod.marime_senzor %></span></p>
                <p>Rezoluție: <span class="rezolutie"><%- locals.prod.rezolutie %> Mpx</span></p>

                <p>Conectivitate / Porturi: <span class="conectivitate"><%- locals.prod.conectivitate %></span></p>

                <p>Stabilizare imagine integrată (IBIS): <span class="ibis"><%- locals.prod.ibis %></span>
                </p>

                <p class="data_lansare">Data lansare:
                    <time class="val-data_lansare" datetime="<%- prod.data_iso %>"><%- prod.data_romana %></time>
                </p>

                <figure class="imag-produs">
                    <img src="/resurse/imagini/produse/<%- locals.prod.imagine %>"
                        alt="[imagine <%- locals.prod.nume %>]" />
                </figure>
            </article>
            <% if (locals.seturi && locals.seturi.length> 0) { %>
                <section class="container mt-5 p-4 rounded border shadow-sm bg-light text-dark mb-4">
                    <h4 class="mb-4 text-center border-bottom pb-2" style="color: var(--col-5);">
                        <i class="fa-solid fa-tags"></i> Acest produs face parte din următoarele pachete promoționale:
                    </h4>
                    <div class="row g-3">
                        <% for (let set of seturi) { %>
                            <div class="col-md-6">
                                <div class="card h-100 border-2"
                                    style="border-color: var(--col-3); background-color: var(--col-1);">
                                    <div class="card-header fw-bold text-white text-center"
                                        style="background-color: var(--col-4);">
                                        <%= set.nume_set %>
                                    </div>
                                    <div class="card-body d-flex flex-column justify-content-between">
                                        <div>
                                            <p class="card-text text-muted" style="font-size: 0.9rem;">
                                                <%= set.descriere_set %>
                                            </p>
                                            <h6 class="mt-2 text-dark">Componentele pachetului:</h6>
                                            <ul style="font-size: 0.9rem;">
                                                <% for (let p of set.produse) { %>
                                                    <li>
                                                        <% if (p.id==prod.id) { %>
                                                            <strong class="text-decoration-underline">
                                                                <%= p.nume %> (Produsul curent)
                                                            </strong>
                                                            <% } else { %>
                                                                <a href="/produs/<%= p.id %>" class="fw-bold text-dark">
                                                                    <%= p.nume %>
                                                                </a>
                                                                <% } %>
                                                    </li>
                                                    <% } %>
                                            </ul>
                                        </div>
                                        <div class="mt-3 p-2 rounded text-center"
                                            style="background-color: var(--col-2); font-weight: bold;">
                                            Preț Special Pachet: <span class="fs-5 text-danger">
                                                <%= set.pretFinal %> RON
                                            </span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <% } %>
                    </div>
                </section>
                <% } %>

        </section>
    </main>

    <%- include("../fragmente/footer") %>
        </body>

</html>